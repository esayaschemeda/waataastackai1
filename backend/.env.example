# =============================================
# StackAI Backend — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to Git
# =============================================

NODE_ENV=production
PORT=4000

# Your Netlify frontend URL (set after deploying frontend)
FRONTEND_URL=https://your-app.netlify.app

# PostgreSQL — get from supabase.com (free)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES=7d

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Stripe — dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Paystack — dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_live_...

# Resend (email) — resend.com (free: 3000 emails/month)
RESEND_API_KEY=re_...
